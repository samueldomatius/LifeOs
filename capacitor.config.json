{
  "appId": "com.samueldomatius.lifeos",
  "appName": "LifeOS",
  "webDir": "dist",
  "android": {
    "allowMixedContent": true,
    "webContentsDebuggingEnabled": false,
    "loggingBehavior": "none"
  },
  "server": {
    "allowNavigation": [
      "generativelanguage.googleapis.com",
      "openrouter.ai",
      "fcm.googleapis.com",
      "firebase.googleapis.com",
      "*.supabase.co",
      "*.railway.app",
      "*.onrender.com"
    ]
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon_config_sample",
      "iconColor": "#7C3AED",
      "sound": "default"
    },
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    }
  }
}
