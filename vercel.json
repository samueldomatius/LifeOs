{
  "version": 2,
  "buildCommand": "npx prisma generate && npx vite build",
  "outputDirectory": "dist",
  "installCommand": "npm install --include=dev",
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.js"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "prisma/schema.prisma"
    }
  }
}